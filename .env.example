# --- Core ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Supabase Postgres) ---
# Use the "Session pooler" connection string from Supabase → Project Settings → Database.
# For Prisma the recommended port is 5432 with pgbouncer=false, schema=public.
# The aws-X portion is region-shard-specific — copy the exact pooler host from
# Supabase Dashboard → Project Settings → Database → Session pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-west-2.pooler.supabase.com:5432/postgres?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Supabase ---
SUPABASE_URL=https://zgublzgoejdzexwpicvb.supabase.co
SUPABASE_ANON_KEY=                       # public anon/publishable key (apps/web only)
SUPABASE_SERVICE_ROLE_KEY=               # server-only key; never expose to apps/web

# --- Spotify OAuth ---
SPOTIFY_CLIENT_ID=
# Redirect URI registered in the Spotify Developer Dashboard.
# Use the Supabase Edge Function URL so the public URL is stable in dev + prod.
SPOTIFY_REDIRECT_URI=https://zgublzgoejdzexwpicvb.supabase.co/functions/v1/spotify-callback

# --- Crypto (32-byte base64) ---
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 64
HOST_JWT_SECRET=

# --- Web ---
# Where the Edge Function redirects the host after a successful callback.
WEB_AUTH_COMPLETE_URL=http://localhost:3001/auth/complete
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://zgublzgoejdzexwpicvb.supabase.co
