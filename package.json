{
  "name": "fairplay-party-dj",
  "version": "0.1.0",
  "private": true,
  "description": "FairPlay Party DJ — host-controlled, guest-influenced Spotify party queue.",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "test:integration": "nx run-many -t test:integration",
    "dev:api": "nx run @fairplay/api:start:dev",
    "dev:web": "nx run @fairplay/web:dev",
    "dev:runner": "nx run @fairplay/runner:start:dev",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down -v"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@nx/jest": "^19.6.0",
    "@nx/nest": "^19.6.0",
    "@nx/next": "^19.6.0",
    "@nx/node": "^19.6.0",
    "@nx/workspace": "^19.6.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nx": "^19.6.0",
    "prettier": "^3.3.0",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.18.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.3.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0"
  }
}
